{
	"name": "@epicenter/svelte",
	"version": "0.3.0",
	"private": true,
	"type": "module",
	"description": "Svelte 5 bindings for Epicenter: reactive workspace state, persisted state, and the auth/session adapter.",
	"keywords": [
		"svelte",
		"local-first",
		"CRDT",
		"epicenter",
		"workspace",
		"reactive state"
	],
	"exports": {
		".": "./src/index.ts",
		"./auth": "./src/auth.svelte.ts",
		"./auth/tauri": "./src/auth-tauri.svelte.ts"
	},
	"dependencies": {
		"@epicenter/auth": "workspace:*",
		"@epicenter/identity": "workspace:*",
		"@epicenter/workspace": "workspace:*",
		"arktype": "catalog:",
		"wellcrafted": "catalog:"
	},
	"peerDependencies": {
		"@tauri-apps/api": "^2",
		"@tauri-apps/plugin-deep-link": "^2",
		"@tauri-apps/plugin-opener": "^2"
	},
	"peerDependenciesMeta": {
