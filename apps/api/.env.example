# apps/api Bun entry (server.ts) — the Bun/self-host runtime port.
#
# `bun run dev:bun` runs the same server as `wrangler dev` against plain
# Postgres + S3, no Cloudflare account. Bun auto-loads this file when copied to
# `.env`. (The `dev` script, which runs `wrangler dev`, ignores this file and
# reads secrets from Infisical instead.)

# Required: Postgres connection string (any Postgres: local Docker, Neon, ...).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/epicenter

# Required: Better Auth signing secret (any high-entropy string).
BETTER_AUTH_SECRET=replace-me

# Hosted social sign-in providers (email/password is disabled). The shared
# server library still registers providers only when present, but this hosted
# API entry requires all four because its UI always shows all four buttons.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Listen port and public origin. The origin must match where the process is
# actually reachable: it becomes the auth baseURL, OAuth issuer, and token
# audience. Defaults to http://localhost:<PORT> (8788, off wrangler's 8787).
PORT=8788
# API_PUBLIC_ORIGIN=http://localhost:8788

# Room update logs: one bun:sqlite file per room under this directory. Keep it
# on a local disk (WAL does not work on networked filesystems).
DATA_DIR=./.data/rooms

# Object storage for content-addressed blobs. Omit to run without blobs (the
# routes answer 503). For a faithful local store, run `docker compose up -d` in
# this directory: it starts versitygw (an S3 API over a plain folder) on :7070
# and creates the bucket. Then uncomment the values below. The store is
# endpoint-as-config: swap versitygw for Garage, AWS S3, or R2 by changing only
# the endpoint + credentials, never the code. (For R2, the endpoint is
# https://<accountId>.r2.cloudflarestorage.com and the region is `auto`.)
# BLOBS_S3_ENDPOINT=http://localhost:7070
# BLOBS_S3_ACCESS_KEY_ID=epicenter-local
# BLOBS_S3_SECRET_ACCESS_KEY=epicenter-local-secret
# BLOBS_S3_BUCKET=epicenter-blobs
# BLOBS_S3_REGION=us-east-1

# AI gateway house keys (optional; a request for a provider 503s without its key).
# OPENAI_API_KEY=
# GEMINI_API_KEY=
