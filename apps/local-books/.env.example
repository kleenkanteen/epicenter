# local-books provider credentials (ADR-0105).
#
# QuickBooks issues a distinct Intuit OAuth keyset per environment, so the name
# carries the environment: `--qb-env sandbox` reads the QB_SANDBOX_* keyset,
# `--qb-env production` reads QB_PRODUCTION_*. Set only the environments you run.
#
# In the monorepo, keep these in your personal Infisical project at
# prod /apps/local-books and inject them with the app-local .infisical.json.
# Get your keys from https://developer.intuit.com ("Keys & credentials"). This
# file is the source of the canonical names; a drift test pins it to QB_SPEC
# (see test/env-example.test.ts).

# QB (set only the environments you run)
# sandbox
QB_SANDBOX_CLIENT_ID=
QB_SANDBOX_CLIENT_SECRET=
# production
QB_PRODUCTION_CLIENT_ID=
QB_PRODUCTION_CLIENT_SECRET=
