# local-books provider credentials (ADR-0105).
#
# QuickBooks issues a distinct Intuit OAuth keyset per environment, so the name
# carries the environment: `--qb-env sandbox` reads the QB_SANDBOX_* keyset,
# `--qb-env production` reads QB_PRODUCTION_*. Set only the environments you run.
#
# Which secret store holds a given name is an orthogonal access-control choice:
# keep the production keyset in a locked-down vault and the sandbox keyset in a
# dev vault, or put both in one env for a single injection. Because the name is
# qualified, every placement is safe. Get your keys from https://developer.intuit.com
# ("Keys & credentials"). This file is the source of the canonical names; a drift
# test pins it to QB_SPEC (see test/env-example.test.ts).

# QB (set only the environments you run)
# sandbox
QB_SANDBOX_CLIENT_ID=
QB_SANDBOX_CLIENT_SECRET=
# production
QB_PRODUCTION_CLIENT_ID=
QB_PRODUCTION_CLIENT_SECRET=
