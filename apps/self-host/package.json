{
	"name": "@epicenter/self-host",
	"description": "Self-hosted single-partition instance (community-supported): one operator-supplied bearer, an off-Cloudflare Bun entry and a Cloudflare Worker reference",
	"private": true,
	"version": "0.0.2",
	"type": "module",
	"exports": {
		".": "./worker/index.ts"
	},
	"license": "AGPL-3.0-or-later",
	"scripts": {
		"dev": "bun --watch server.ts",
		"typecheck": "tsc --noEmit",
		"typegen": "wrangler types",
		"deploy": "wrangler deploy",
		"gen-token": "bun scripts/gen-token.ts"
	},
	"dependencies": {
		"@epicenter/auth": "workspace:*",
		"@epicenter/constants": "workspace:*",
		"@epicenter/identity": "workspace:*",
		"@epicenter/server": "workspace:*",
		"arktype": "catalog:",
		"hono": "catalog:"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260405.1",
		"@types/bun": "catalog:",
		"typescript": "catalog:",
		"wrangler": "catalog:"
	}
}
