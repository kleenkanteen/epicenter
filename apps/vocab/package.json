{
	"name": "@epicenter/vocab",
	"description": "Multilingual chat tutor with a deterministic client-side reading overlay",
	"private": true,
	"version": "0.0.2",
	"type": "module",
	"exports": {
		".": "./vocab.ts",
		"./browser": "./vocab.browser.ts"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "NODE_ENV=production vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"test": "if find src -name '*.test.ts' -o -name '*.test.tsx' -o -name '*.spec.ts' | grep -q .; then bun test; fi",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"deploy": "wrangler deploy"
	},
	"dependencies": {
		"@epicenter/app-shell": "workspace:*",
		"@epicenter/auth": "workspace:*",
		"@epicenter/chat": "workspace:*",
		"@epicenter/client": "workspace:*",
		"@epicenter/constants": "workspace:*",
		"@epicenter/field": "workspace:*",
		"@epicenter/recorder": "workspace:*",
		"@epicenter/svelte": "workspace:*",
		"@epicenter/ui": "workspace:*",
		"@epicenter/workspace": "workspace:*",
		"@lucide/svelte": "catalog:",
		"arktype": "catalog:",
		"mode-watcher": "^1.1.0",
		"pinyin-pro": "^3.28.0",
		"svelte-sonner": "catalog:",
		"transliteration": "^2.6.1",
		"typebox": "catalog:",
		"wanakana": "^5.3.1",
		"wellcrafted": "catalog:",
		"yjs": "catalog:"
	},
	"devDependencies": {
		"@epicenter/vite-config": "workspace:*",
		"@sveltejs/adapter-static": "catalog:",
		"@sveltejs/kit": "catalog:",
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"@types/bun": "catalog:",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vite-plugin-static-copy": "^4.1.1"
	},
	"license": "AGPL-3.0-or-later"
}
