{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Local Mail",
	"version": "0.0.1",
	"identifier": "so.epicenter.local-mail",
	"build": {
		"beforeBuildCommand": "bun run build:desktop",
		"frontendDist": "placeholder-dist"
	},
	"app": {
		"windows": [],
		"security": {
			"csp": "default-src 'self'"
		}
	},
	"bundle": {
		"active": true,
		"targets": ["app"],
		"category": "Productivity",
		"publisher": "Epicenter",
		"copyright": "Copyright © 2026 Epicenter",
		"shortDescription": "Native window over the local Bun mail engine",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"externalBin": ["binaries/local-mail-engine"],
		"resources": {
			"../ui/dist/": "ui-dist"
		},
		"macOS": {
			"minimumSystemVersion": "10.15"
		}
	}
}
