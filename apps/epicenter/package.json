{
	"name": "@epicenter/epicenter",
	"description": "One desktop application host serving trusted Epicenter SPAs and the Query session from Bun.",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"exports": {
		".": "./src/host.ts"
	},
	"scripts": {
		"dev": "bun run dev:desktop",
		"dev:desktop": "tauri dev --config src-tauri/tauri.dev.conf.json",
		"remote:dev": "bun run scripts/remote-dev-smoke.ts",
		"build": "vite build",
		"build:sidecar": "bun run scripts/build-sidecar.ts",
		"build:desktop": "bun run build && bun run build:sidecar",
		"desktop:build": "tauri build",
		"test": "bun test",
		"tauri": "tauri",
		"typecheck": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json"
	},
	"dependencies": {
		"@epicenter/chat": "workspace:*",
		"@epicenter/client": "workspace:*",
		"@epicenter/honeycrisp": "workspace:*",
		"@epicenter/server": "workspace:*",
		"@epicenter/todos": "workspace:*",
		"@epicenter/ui": "workspace:*",
		"@epicenter/workspace": "workspace:*",
		"@modelcontextprotocol/sdk": "catalog:",
		"@tauri-apps/api": "catalog:",
		"hono": "catalog:",
		"yjs": "catalog:"
	},
	"devDependencies": {
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"@tauri-apps/cli": "catalog:",
		"@types/bun": "catalog:",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vite-plugin-singlefile": "catalog:"
	},
	"license": "AGPL-3.0-or-later"
}
