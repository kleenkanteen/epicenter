{
	"name": "@epicenter/epicenter",
	"description": "One desktop application host serving trusted Epicenter SPAs and the Query session from Bun.",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"exports": {
		".": "./src/host.ts"
	},
	"scripts": {
		"dev": "bun run dev:desktop",
		"dev:desktop": "tauri dev --config src-tauri/tauri.dev.conf.json",
		"remote:dev": "bun run scripts/remote-dev-smoke.ts",
		"build": "bun run clean:dist && bun run build:query && bun run build:whispering",
		"build:query": "vite build",
		"build:sidecar": "bun run scripts/build-sidecar.ts",
		"build:whispering": "TAURI_ENV_PLATFORM=macos bun run --cwd whispering build",
		"clean:dist": "bun run scripts/clean-dist.ts",
		"build:desktop": "bun run build && bun run build:sidecar",
		"desktop:build": "tauri build",
		"test": "bun test",
		"tauri": "tauri",
		"typecheck": "bun run typecheck:query && bun run --cwd whispering typecheck",
		"typecheck:query": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json"
	},
	"dependencies": {
		"@aptabase/tauri": "^0.4.1",
		"@aptabase/web": "^0.4.3",
		"@epicenter/app-shell": "workspace:*",
		"@epicenter/auth": "workspace:*",
		"@epicenter/chat": "workspace:*",
		"@epicenter/client": "workspace:*",
		"@epicenter/constants": "workspace:*",
		"@epicenter/field": "workspace:*",
		"@epicenter/honeycrisp": "workspace:*",
		"@epicenter/recorder": "workspace:*",
		"@epicenter/server": "workspace:*",
		"@epicenter/svelte": "workspace:*",
		"@epicenter/todos": "workspace:*",
		"@epicenter/ui": "workspace:*",
		"@epicenter/workspace": "workspace:*",
		"@mistralai/mistralai": "^1.9.18",
		"@modelcontextprotocol/sdk": "catalog:",
		"@standard-schema/spec": "catalog:",
		"@tanstack/svelte-query": "catalog:",
		"@tanstack/svelte-table": "catalog:",
		"@tanstack/table-core": "9.0.0-alpha.10",
		"@tauri-apps/api": "catalog:",
		"@tauri-apps/plugin-autostart": "^2.0.1",
		"@tauri-apps/plugin-clipboard-manager": "^2.3.0",
		"@tauri-apps/plugin-deep-link": "catalog:",
		"@tauri-apps/plugin-dialog": "^2.3.2",
		"@tauri-apps/plugin-fs": "catalog:",
		"@tauri-apps/plugin-global-shortcut": "^2.3.0",
		"@tauri-apps/plugin-http": "2.5.4",
		"@tauri-apps/plugin-log": "~2",
		"@tauri-apps/plugin-notification": "^2.3.0",
		"@tauri-apps/plugin-opener": "catalog:",
		"@tauri-apps/plugin-os": "^2.3.0",
		"@tauri-apps/plugin-process": "^2.3.0",
		"@tauri-apps/plugin-updater": "^2.9.0",
		"arkregex": "catalog:",
		"arktype": "catalog:",
		"audio-recorder-polyfill": "^0.4.1",
		"bits-ui": "catalog:",
		"date-fns": "catalog:",
		"dexie": "^4.0.11",
		"dompurify": "^3.4.10",
		"elevenlabs": "^1.59.0",
		"fflate": "catalog:",
		"hono": "catalog:",
		"idb": "^8.0.3",
		"js-yaml": "^4.1.1",
		"marked": "catalog:",
		"mime": "catalog:",
		"nanoid": "catalog:",
		"tailwind-variants": "catalog:",
		"typebox": "catalog:",
		"wellcrafted": "catalog:",
		"yjs": "catalog:"
	},
	"devDependencies": {
		"@epicenter/vite-config": "workspace:*",
		"@lucide/svelte": "catalog:",
		"@sveltejs/adapter-static": "catalog:",
		"@sveltejs/kit": "catalog:",
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"@tailwindcss/typography": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"@tauri-apps/cli": "catalog:",
		"@types/bun": "catalog:",
		"@types/js-yaml": "^4.0.9",
		"mode-watcher": "catalog:",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"svelte-sonner": "catalog:",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vite-plugin-devtools-json": "^1.0.0",
		"vite-plugin-static-copy": "^4.1.1",
		"vite-plugin-singlefile": "catalog:",
		"wrangler": "catalog:"
	},
	"license": "AGPL-3.0-or-later"
}
