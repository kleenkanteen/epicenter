{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "trusted-whispering-native-production",
	"description": "Grants only the production Whispering surface its recording, transcription, delivery, and supporting desktop authority.",
	"local": false,
	"windows": ["whispering"],
	"remote": {
		"urls": ["http://127.0.0.1:39130"]
	},
	"permissions": [
		"core:default",
		"core:event:allow-emit",
		"core:event:allow-listen",
		"core:window:allow-hide",
		"core:window:allow-show",
		"core:window:allow-close",
		"core:window:allow-set-focus",
		"core:window:allow-unminimize",
		"core:window:allow-set-size",
		"core:window:allow-set-position",
		"allow-write-text",
		"allow-simulate-enter-keystroke",
		"allow-simulate-copy-keystroke",
		"allow-get-current-recording-id",
		"allow-enumerate-recording-devices",
		"allow-init-recording-session",
		"allow-close-recording-session",
		"allow-start-recording",
		"allow-stop-recording",
		"allow-cancel-recording",
		"allow-delete-recording-artifacts",
		"allow-clear-recording-artifacts",
		"allow-read-recording-artifact",
		"allow-encode-recording-for-upload",
		"allow-transcribe-recording",
		"allow-prewarm-model",
		"allow-open-accessibility-settings",
		"allow-request-accessibility-permission",
		"allow-get-microphone-permission",
		"allow-request-microphone-permission",
		"allow-set-unload-policy",
		"allow-list-models",
		"allow-download-model",
		"allow-delete-model",
		"allow-cancel-download",
		"allow-pause-playback",
		"allow-resume-playback",
		"allow-keyring-read",
		"allow-keyring-write",
		"allow-set-auto-paste-enabled",
		"allow-get-dictation-capability",
		"clipboard-manager:allow-read-text",
		"clipboard-manager:allow-write-text",
		"dialog:allow-open",
		"dialog:allow-save",
		"global-shortcut:allow-is-registered",
		"global-shortcut:allow-register",
		"global-shortcut:allow-unregister",
		"global-shortcut:allow-register-all",
		"global-shortcut:allow-unregister-all",
		"log:default",
		"macos-permissions:default",
		"opener:allow-default-urls",
		"opener:allow-open-url"
	]
}
