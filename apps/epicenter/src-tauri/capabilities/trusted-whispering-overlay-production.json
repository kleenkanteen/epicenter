{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "trusted-whispering-overlay-production",
	"description": "Allows the production Whispering recording overlay to exchange only its status and action events.",
	"local": false,
	"windows": ["recording-overlay"],
	"remote": {
		"urls": ["http://127.0.0.1:39130"]
	},
	"permissions": [
		"core:event:allow-emit",
		"core:event:allow-listen",
		"log:default"
	]
}
