{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "trusted-whispering-overlay-development",
	"description": "Development origin variant of the event-only Whispering recording overlay capability.",
	"local": false,
	"windows": ["recording-overlay"],
	"remote": {
		"urls": ["http://127.0.0.1:*"]
	},
	"permissions": [
		"core:event:allow-emit",
		"core:event:allow-listen",
		"log:default"
	]
}
