{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Epicenter",
	"version": "0.0.1",
	"identifier": "so.epicenter.app",
	"build": {
		"beforeBuildCommand": "bun run build:desktop",
		"beforeDevCommand": {
			"script": "bun run build",
			"wait": true
		},
		"frontendDist": "frontend-placeholder"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [],
		"security": {
			"capabilities": [
				"trusted-epicenter-apps-production",
				"trusted-whispering-native-production",
				"trusted-whispering-overlay-production"
			],
			"csp": "default-src 'none'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
		}
	},
	"bundle": {
		"active": true,
		"targets": ["app"],
		"category": "Productivity",
		"publisher": "Epicenter",
		"copyright": "Copyright © 2026 Epicenter",
		"shortDescription": "One trusted desktop host for Epicenter apps",
		"externalBin": ["binaries/epicenter-host"],
		"resources": {
			"../dist": "apps-dist",
			"recorder-state-icons/studio_microphone.png": "recorder-state-icons/studio_microphone.png",
			"recorder-state-icons/red_large_square.png": "recorder-state-icons/red_large_square.png"
		},
		"icon": ["icons/icon.png", "icons/icon.icns"],
		"macOS": {
			"entitlements": "entitlements.plist",
			"hardenedRuntime": true,
			"minimumSystemVersion": "10.15"
		}
	},
	"plugins": {
		"deep-link": {
			"desktop": {
				"schemes": ["epicenter"]
			}
		}
	}
}
