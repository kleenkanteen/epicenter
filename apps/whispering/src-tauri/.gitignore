# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# Staged by build.rs: transcribe-cpp's shared runtime libraries + ggml backend
# modules (the Linux / x86_64-Windows dynamic-backends posture). Tauri bundles
# the folder beside the executable; the copied binaries are build artifacts, so
# never commit them. Empty on the static targets (macOS Metal, aarch64 Windows).
/transcribe-libs/

# Environment variables
.env
.env.local
